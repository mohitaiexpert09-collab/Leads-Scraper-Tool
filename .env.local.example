# ── Supabase (leave BLANK to run in demo mode with in-memory sample data) ──
# Create a project at https://supabase.com, then Project Settings → API:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Automated scraping (optional — powers the "Scrape Now" button + daily cron) ──
# Apify API token: https://console.apify.com/settings/integrations
APIFY_TOKEN=
# Supabase service_role key (Project Settings → API → service_role secret).
# Used by cron/webhooks to store leads when no user is logged in. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=
# Any long random string. Secures the cron + Apify webhook endpoints.
CRON_SECRET=
# Your deployed URL (no trailing slash), e.g. https://leads-scraper-tool.vercel.app
# Required so Apify webhooks can call back to store results. Use http://localhost:3000 locally.
NEXT_PUBLIC_SITE_URL=

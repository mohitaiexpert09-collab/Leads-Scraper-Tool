# ── Supabase (leave BLANK to run in demo mode with in-memory sample data) ──
# Create a project at https://supabase.com, then Project Settings → API:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Apify (optional) ──
# Only needed to auto-run scrapers from the app. Until then, run the actors in
# your Claude session and use the Import screen. Get a token at
# https://console.apify.com/account/integrations
APIFY_TOKEN=
